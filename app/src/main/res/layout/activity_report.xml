<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/bg"
    android:orientation="vertical">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="56dp"
        android:background="@color/white"
        android:gravity="center_vertical"
        android:orientation="horizontal"
        android:paddingStart="12dp"
        android:paddingEnd="12dp"
        android:elevation="2dp">

        <ImageView
            android:id="@+id/btnBack"
            android:layout_width="36dp"
            android:layout_height="36dp"
            android:padding="6dp"
            android:src="@drawable/ic_chevron_left"
            android:clickable="true"
            android:focusable="true"
            app:tint="@color/text_dark" />

        <TextView
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="@string/report_title"
            android:textColor="@color/text_dark"
            android:textSize="17sp"
            android:textStyle="bold"
            android:layout_marginStart="8dp" />
    </LinearLayout>

    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:fillViewport="true">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="20dp">

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="@string/report_reason_label"
                android:textColor="@color/text_muted"
                android:textSize="12sp"
                android:textStyle="bold"
                android:letterSpacing="0.06"
                android:layout_marginBottom="10dp" />

            <RadioGroup
                android:id="@+id/rgReasons"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical">

                <RadioButton android:id="@+id/rbSpam"
                    android:layout_width="match_parent" android:layout_height="wrap_content"
                    android:text="@string/report_reason_spam" android:textColor="@color/text_dark"
                    android:paddingTop="8dp" android:paddingBottom="8dp"/>
                <RadioButton android:id="@+id/rbHarass"
                    android:layout_width="match_parent" android:layout_height="wrap_content"
                    android:text="@string/report_reason_harass" android:textColor="@color/text_dark"
                    android:paddingTop="8dp" android:paddingBottom="8dp"/>
                <RadioButton android:id="@+id/rbInappropriate"
                    android:layout_width="match_parent" android:layout_height="wrap_content"
                    android:text="@string/report_reason_inappropriate" android:textColor="@color/text_dark"
                    android:paddingTop="8dp" android:paddingBottom="8dp"/>
                <RadioButton android:id="@+id/rbImpersonation"
                    android:layout_width="match_parent" android:layout_height="wrap_content"
                    android:text="@string/report_reason_impersonation" android:textColor="@color/text_dark"
                    android:paddingTop="8dp" android:paddingBottom="8dp"/>
                <RadioButton android:id="@+id/rbOther"
                    android:layout_width="match_parent" android:layout_height="wrap_content"
                    android:text="@string/report_reason_other" android:textColor="@color/text_dark"
                    android:paddingTop="8dp" android:paddingBottom="8dp"/>
            </RadioGroup>

            <EditText
                android:id="@+id/etDescription"
                android:layout_width="match_parent"
                android:layout_height="100dp"
                android:background="@drawable/bg_input"
                android:gravity="top"
                android:hint="@string/report_desc_hint"
                android:inputType="textMultiLine"
                android:padding="14dp"
                android:textColor="@color/text_dark"
                android:textColorHint="@color/text_muted"
                android:textSize="14sp"
                android:layout_marginTop="14dp"
                android:visibility="gone" />

            <Button
                android:id="@+id/btnSubmitReport"
                android:layout_width="match_parent"
                android:layout_height="48dp"
                android:background="@drawable/bg_btn_primary"
                android:text="@string/report_submit"
                android:textColor="@color/white"
                android:textSize="14sp"
                android:textStyle="bold"
                android:layout_marginTop="20dp"
                style="?android:attr/borderlessButtonStyle" />
        </LinearLayout>
    </ScrollView>
</LinearLayout>
