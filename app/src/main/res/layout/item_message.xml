<?xml version="1.0" encoding="utf-8"?>
<!--
    item_message.xml — layout dùng chung cho cả tin nhắn mình (END) và đối phương (START).
    ChatAdapter sẽ switch gravity + background + màu chữ theo viewType.
-->
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/layoutMessageRoot"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="horizontal"
    android:gravity="end"
    android:layout_marginBottom="6dp"
    android:paddingStart="4dp"
    android:paddingEnd="4dp">

    <!-- Avatar đối phương — ẩn khi isMine, hiện khi đối phương gửi -->
    <androidx.cardview.widget.CardView
        android:id="@+id/cvPartnerAvatar"
        android:layout_width="32dp"
        android:layout_height="32dp"
        android:layout_marginEnd="6dp"
        android:layout_gravity="bottom"
        android:visibility="gone"
        app:cardCornerRadius="16dp"
        app:cardElevation="0dp">

        <ImageView
            android:id="@+id/ivMsgAvatar"
            android:layout_width="32dp"
            android:layout_height="32dp"
            android:scaleType="centerCrop"
            android:src="@android:drawable/sym_def_app_icon" />
    </androidx.cardview.widget.CardView>

    <!-- Bubble wrapper — max 72% chiều rộng màn hình -->
    <LinearLayout
        android:id="@+id/layoutBubble"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:maxWidth="260dp"
        android:orientation="vertical"
        android:background="@drawable/bg_bubble_me"
        android:paddingStart="12dp"
        android:paddingEnd="12dp"
        android:paddingTop="8dp"
        android:paddingBottom="8dp">

        <!-- Tin nhắn text (ẩn khi type=image) -->
        <TextView
            android:id="@+id/tvMessageText"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:textColor="@color/white"
            android:textSize="14sp"
            android:lineSpacingExtra="2dp"
            tools:text="Xin chào bạn!" />

        <!-- Ảnh (ẩn khi type=text) — hiện khi type=image -->
        <ImageView
            android:id="@+id/ivMsgImage"
            android:tag="ivMsgImage"
            android:layout_width="200dp"
            android:layout_height="150dp"
            android:scaleType="centerCrop"
            android:visibility="gone"
            android:src="@drawable/ic_image_placeholder" />

        <!-- Bản dịch — ẩn mặc định, hiện khi user long press → dịch -->
        <TextView
            android:id="@+id/tvMessageTranslation"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:textColor="#CCFFFFFF"
            android:textSize="12sp"
            android:fontStyle="italic"
            android:layout_marginTop="4dp"
            android:paddingTop="4dp"
            android:visibility="gone"
            tools:text="Hello!" />

        <!-- Divider mỏng giữa bản dịch và timestamp (chỉ hiện khi có dịch) -->
        <View
            android:id="@+id/dividerTranslation"
            android:layout_width="match_parent"
            android:layout_height="0.5dp"
            android:background="#33FFFFFF"
            android:layout_marginTop="4dp"
            android:visibility="gone" />

        <!-- Timestamp + trạng thái (sent/delivered/read) -->
        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_gravity="end"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:layout_marginTop="4dp">

            <TextView
                android:id="@+id/tvMessageTime"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:textColor="#99FFFFFF"
                android:textSize="10sp"
                tools:text="10:30" />

            <!-- Tick trạng thái: chỉ hiện với tin nhắn của mình -->
            <TextView
                android:id="@+id/tvMessageStatus"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:textColor="#99FFFFFF"
                android:textSize="10sp"
                android:layout_marginStart="3dp"
                android:visibility="gone"
                tools:text="✓✓" />
        </LinearLayout>
    </LinearLayout>

</LinearLayout>
