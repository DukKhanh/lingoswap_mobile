<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/bg"
    android:orientation="vertical">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="60dp"
        android:background="@color/white"
        android:gravity="center_vertical"
        android:orientation="horizontal"
        android:paddingStart="12dp"
        android:paddingEnd="12dp"
        android:elevation="2dp">

        <ImageView
            android:id="@+id/btnBack"
            android:layout_width="36dp"
            android:layout_height="36dp"
            android:padding="6dp"
            android:src="@drawable/ic_chevron_left"
            android:clickable="true"
            android:focusable="true"
            app:tint="@color/text_dark" />

        <FrameLayout
            android:layout_width="40dp"
            android:layout_height="40dp"
            android:layout_marginStart="8dp">

            <androidx.cardview.widget.CardView
                android:layout_width="40dp"
                android:layout_height="40dp"
                app:cardCornerRadius="20dp"
                app:cardElevation="0dp">

                <ImageView
                    android:id="@+id/ivPartnerAvatar"
                    android:layout_width="40dp"
                    android:layout_height="40dp"
                    android:scaleType="centerCrop"
                    android:src="@drawable/ic_avatar_placeholder" />
            </androidx.cardview.widget.CardView>

            <View
                android:id="@+id/viewOnlineDot"
                android:layout_width="11dp"
                android:layout_height="11dp"
                android:layout_gravity="bottom|end"
                android:background="@drawable/bg_online_dot" />
        </FrameLayout>

        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:orientation="vertical"
            android:paddingStart="10dp">

            <TextView
                android:id="@+id/tvPartnerName"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Nguyen Van A"
                android:textColor="@color/text_dark"
                android:textSize="15sp"
                android:textStyle="bold" />

            <TextView
                android:id="@+id/tvPartnerStatus"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/label_online"
                android:textColor="@color/blue"
                android:textSize="12sp" />
        </LinearLayout>

        <TextView
            android:id="@+id/tvLangTag"
            android:layout_width="wrap_content"
            android:layout_height="28dp"
            android:background="@drawable/bg_toggle_group"
            android:gravity="center"
            android:paddingStart="10dp"
            android:paddingEnd="10dp"
            android:text="VI → EN"
            android:textColor="@color/blue"
            android:textSize="11sp"
            android:textStyle="bold"
            android:layout_marginEnd="8dp" />

        <ImageView
            android:id="@+id/btnReport"
            android:layout_width="36dp"
            android:layout_height="36dp"
            android:padding="7dp"
            android:layout_marginEnd="4dp"
            android:src="@android:drawable/ic_menu_report_image"
            android:clickable="true"
            android:focusable="true"
            android:contentDescription="@string/report_title"
            app:tint="@color/text_muted" />

        <ImageView
            android:id="@+id/btnVideoCall"
            android:layout_width="36dp"
            android:layout_height="36dp"
            android:background="@drawable/bg_btn_primary"
            android:padding="8dp"
            android:src="@android:drawable/ic_menu_call"
            android:clickable="true"
            android:focusable="true"
            app:tint="@color/white" />
    </LinearLayout>

    <TextView
        android:id="@+id/tvDateDivider"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_gravity="center_horizontal"
        android:layout_marginTop="10dp"
        android:layout_marginBottom="2dp"
        android:background="@drawable/bg_toggle_group"
        android:paddingStart="14dp"
        android:paddingEnd="14dp"
        android:paddingTop="4dp"
        android:paddingBottom="4dp"
        android:text="@string/chat_today"
        android:textColor="@color/text_muted"
        android:textSize="11sp" />

    <androidx.recyclerview.widget.RecyclerView
        android:id="@+id/rvMessages"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:clipToPadding="false"
        android:paddingStart="12dp"
        android:paddingEnd="12dp"
        android:paddingTop="8dp"
        android:paddingBottom="8dp"
        android:scrollbars="none" />

    <LinearLayout
        android:id="@+id/layoutTranslateTip"
        android:layout_width="match_parent"
        android:layout_height="38dp"
        android:background="@color/white"
        android:gravity="center"
        android:orientation="horizontal"
        android:visibility="gone">

        <ImageView
            android:layout_width="16dp"
            android:layout_height="16dp"
            android:src="@drawable/ic_globe"
            app:tint="@color/text_muted"
            android:layout_marginEnd="6dp" />

        <TextView
            android:id="@+id/tvTranslationResult"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="@string/chat_translating"
            android:textColor="@color/text_mid"
            android:textSize="13sp" />

        <ImageView
            android:id="@+id/btnCloseTranslate"
            android:layout_width="28dp"
            android:layout_height="28dp"
            android:padding="4dp"
            android:src="@android:drawable/ic_menu_close_clear_cancel"
            android:clickable="true"
            android:focusable="true"
            app:tint="@color/text_muted" />
    </LinearLayout>

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="@color/white"
        android:gravity="center_vertical"
        android:orientation="horizontal"
        android:paddingStart="10dp"
        android:paddingEnd="10dp"
        android:paddingTop="8dp"
        android:paddingBottom="8dp"
        android:elevation="4dp">

        <ImageView
            android:id="@+id/btnEmoji"
            android:layout_width="36dp"
            android:layout_height="36dp"
            android:padding="6dp"
            android:src="@android:drawable/ic_menu_add"
            android:clickable="true"
            android:focusable="true"
            app:tint="@color/text_muted" />

        <EditText
            android:id="@+id/etMessage"
            android:layout_width="0dp"
            android:layout_height="44dp"
            android:layout_weight="1"
            android:background="@drawable/bg_input"
            android:hint="@string/chat_hint"
            android:textColor="@color/text_dark"
            android:textColorHint="@color/text_muted"
            android:textSize="14sp"
            android:paddingStart="14dp"
            android:paddingEnd="14dp"
            android:inputType="textMultiLine"
            android:maxLines="4"
            android:layout_marginStart="6dp"
            android:layout_marginEnd="6dp" />

        <ImageView
            android:id="@+id/btnSend"
            android:layout_width="40dp"
            android:layout_height="40dp"
            android:background="@drawable/bg_btn_primary"
            android:padding="10dp"
            android:src="@android:drawable/ic_menu_send"
            android:clickable="true"
            android:focusable="true"
            app:tint="@color/white" />
    </LinearLayout>

</LinearLayout>
