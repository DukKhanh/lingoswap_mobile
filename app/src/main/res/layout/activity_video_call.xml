<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/video_bg"
    android:orientation="vertical">

    <FrameLayout
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:background="@color/video_main_bg">

        <org.webrtc.SurfaceViewRenderer
            android:id="@+id/remoteVideoView"
            android:layout_width="match_parent"
            android:layout_height="match_parent" />

        <ImageView
            android:id="@+id/imgPartnerAvatar"
            android:layout_width="140dp"
            android:layout_height="140dp"
            android:layout_gravity="center"
            android:scaleType="centerCrop"
            android:contentDescription="@string/video_connecting" />

        <TextView
            android:id="@+id/tvPartnerName"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_gravity="bottom|start"
            android:layout_margin="16dp"
            android:text="@string/video_connecting"
            android:textColor="@color/white"
            android:textSize="16sp"
            android:textStyle="bold"
            android:shadowColor="#000000"
            android:shadowDx="1"
            android:shadowDy="1"
            android:shadowRadius="2"/>

        <TextView
            android:id="@+id/tvCallTimer"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_gravity="top|start"
            android:layout_margin="12dp"
            android:background="#66000000"
            android:padding="6dp"
            android:text="00:00"
            android:textColor="@color/white"
            android:textSize="13sp"
            android:fontFamily="monospace"/>

        <org.webrtc.SurfaceViewRenderer
            android:id="@+id/localVideoView"
            android:layout_width="120dp"
            android:layout_height="160dp"
            android:layout_gravity="top|end"
            android:layout_margin="16dp" />

    </FrameLayout>

    <LinearLayout
        android:id="@+id/chatPanel"
        android:layout_width="match_parent"
        android:layout_height="200dp"
        android:background="@color/dark_surface"
        android:orientation="vertical"
        android:visibility="visible">

        <ScrollView
            android:id="@+id/scrollChat"
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_weight="1"
            android:padding="8dp">

            <LinearLayout
                android:id="@+id/chatMessages"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"/>
        </ScrollView>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="44dp"
            android:orientation="horizontal"
            android:background="@color/video_bg"
            android:gravity="center_vertical"
            android:paddingStart="12dp"
            android:paddingEnd="8dp">

            <EditText
                android:id="@+id/etChatInput"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:hint="@string/video_chat_hint"
                android:textColor="@color/white"
                android:textColorHint="#94A3B8"
                android:background="@android:color/transparent"
                android:singleLine="true"
                android:imeOptions="actionSend"/>

            <FrameLayout
                android:id="@+id/btnSendMessage"
                android:layout_width="36dp"
                android:layout_height="36dp"
                android:background="@drawable/bg_btn_primary">
                <ImageView
                    android:layout_width="18dp"
                    android:layout_height="18dp"
                    android:layout_gravity="center"
                    android:src="@drawable/ic_send"
                    android:tint="@color/white"/>
            </FrameLayout>
        </LinearLayout>
    </LinearLayout>

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="80dp"
        android:background="@color/video_bg"
        android:gravity="center"
        android:orientation="horizontal"
        android:paddingStart="12dp"
        android:paddingEnd="12dp">

        <LinearLayout
            android:id="@+id/btnMute"
            android:layout_width="56dp"
            android:layout_height="56dp"
            android:layout_margin="8dp"
            android:background="@drawable/bg_ctrl_btn"
            android:gravity="center"
            android:orientation="vertical">
            <ImageView
                android:id="@+id/tvMuteIcon"
                android:layout_width="24dp"
                android:layout_height="24dp"
                android:src="@drawable/ic_mic"
                android:tint="@color/white"/>
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/video_btn_mic"
                android:textColor="@color/ctrl_label_color"
                android:textSize="9sp"/>
        </LinearLayout>

        <LinearLayout
            android:id="@+id/btnStopVideo"
            android:layout_width="56dp"
            android:layout_height="56dp"
            android:layout_margin="8dp"
            android:background="@drawable/bg_ctrl_btn"
            android:gravity="center"
            android:orientation="vertical">
            <ImageView
                android:id="@+id/tvCameraIcon"
                android:layout_width="24dp"
                android:layout_height="24dp"
                android:src="@drawable/ic_videocam"
                android:tint="@color/white"/>
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/video_btn_camera"
                android:textColor="@color/ctrl_label_color"
                android:textSize="9sp"/>
        </LinearLayout>

        <LinearLayout
            android:id="@+id/btnToggleChat"
            android:layout_width="56dp"
            android:layout_height="56dp"
            android:layout_margin="8dp"
            android:background="@drawable/bg_ctrl_btn"
            android:gravity="center"
            android:orientation="vertical">
            <ImageView
                android:layout_width="24dp"
                android:layout_height="24dp"
                android:src="@drawable/ic_chat"
                android:tint="@color/white"/>
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/video_btn_chat"
                android:textColor="@color/ctrl_label_color"
                android:textSize="9sp"/>
        </LinearLayout>

        <LinearLayout
            android:id="@+id/btnEndCall"
            android:layout_width="56dp"
            android:layout_height="56dp"
            android:layout_margin="8dp"
            android:background="@drawable/bg_ctrl_btn_red"
            android:gravity="center"
            android:orientation="vertical">
            <ImageView
                android:layout_width="24dp"
                android:layout_height="24dp"
                android:src="@drawable/ic_call_end"
                android:tint="@color/white"/>
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/video_btn_end"
                android:textColor="@color/white"
                android:textSize="9sp"/>
        </LinearLayout>
    </LinearLayout>
</LinearLayout>
