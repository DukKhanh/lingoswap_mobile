<?xml version="1.0" encoding="utf-8"?>
<!--
    item_friend.xml
    Đặt tại: app/src/main/res/layout/item_friend.xml

    Dùng cho cả 3 tab:
    - Tab All / Online: hiện nút Chat + Call, ẩn Accept/Reject
    - Tab Requests:     hiện Accept + Reject, ẩn Chat/Call
-->
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="horizontal"
    android:gravity="center_vertical"
    android:paddingTop="10dp"
    android:paddingBottom="10dp"
    android:background="?android:attr/selectableItemBackground">

    <!-- Avatar + status dot -->
    <FrameLayout
        android:layout_width="48dp"
        android:layout_height="48dp"
        android:layout_marginEnd="12dp">

        <androidx.cardview.widget.CardView
            android:layout_width="48dp"
            android:layout_height="48dp"
            app:cardCornerRadius="24dp"
            app:cardElevation="0dp">

            <ImageView
                android:id="@+id/ivAvatar"
                android:layout_width="48dp"
                android:layout_height="48dp"
                android:scaleType="centerCrop"
                android:src="@android:drawable/sym_def_app_icon" />
        </androidx.cardview.widget.CardView>

        <!-- Chữ cái đầu (fallback khi không có ảnh) -->
        <TextView
            android:id="@+id/tvAvatarInitial"
            android:layout_width="48dp"
            android:layout_height="48dp"
            android:gravity="center"
            android:textColor="@color/white"
            android:textSize="18sp"
            android:textStyle="bold"
            android:background="@drawable/bg_avatar"
            android:visibility="visible" />

        <!-- Online dot -->
        <View
            android:id="@+id/viewStatusDot"
            android:layout_width="12dp"
            android:layout_height="12dp"
            android:layout_gravity="bottom|end"
            android:background="@drawable/status_dot_offline" />
    </FrameLayout>

    <!-- Tên + trạng thái / thời gian gửi lời mời -->
    <LinearLayout
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_weight="1"
        android:orientation="vertical">

        <TextView
            android:id="@+id/tvFriendName"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:textColor="@color/text_dark"
            android:textSize="14sp"
            android:textStyle="bold" />

        <TextView
            android:id="@+id/tvFriendStatus"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:textColor="@color/text_muted"
            android:textSize="12sp"
            android:layout_marginTop="2dp" />
    </LinearLayout>

    <!-- Nút Chat + Call (Tab All / Online) -->
    <LinearLayout
        android:id="@+id/layoutActions"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical">

        <ImageView
            android:id="@+id/btnChat"
            android:layout_width="36dp"
            android:layout_height="36dp"
            android:background="@drawable/bg_input"
            android:padding="8dp"
            android:src="@android:drawable/ic_dialog_email"
            android:clickable="true"
            android:focusable="true"
            android:layout_marginEnd="6dp" />

        <ImageView
            android:id="@+id/btnCall"
            android:layout_width="36dp"
            android:layout_height="36dp"
            android:background="@drawable/bg_btn_primary"
            android:padding="8dp"
            android:src="@android:drawable/ic_menu_call"
            android:clickable="true"
            android:focusable="true" />
    </LinearLayout>

    <!-- Nút Accept + Reject (Tab Requests) -->
    <LinearLayout
        android:id="@+id/layoutRequestActions"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:visibility="gone">

        <Button
            android:id="@+id/btnAccept"
            android:layout_width="wrap_content"
            android:layout_height="34dp"
            android:background="@drawable/bg_btn_primary"
            android:text="@string/action_accept"
            android:textColor="@color/white"
            android:textSize="12sp"
            android:paddingStart="12dp"
            android:paddingEnd="12dp"
            android:layout_marginEnd="6dp"
            style="?android:attr/borderlessButtonStyle" />

        <Button
            android:id="@+id/btnReject"
            android:layout_width="wrap_content"
            android:layout_height="34dp"
            android:background="@drawable/bg_btn_outline"
            android:text="@string/action_reject"
            android:textColor="@color/text_muted"
            android:textSize="12sp"
            android:paddingStart="12dp"
            android:paddingEnd="12dp"
            style="?android:attr/borderlessButtonStyle" />
    </LinearLayout>

</LinearLayout>
