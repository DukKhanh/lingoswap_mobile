<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="horizontal"
    android:gravity="center_vertical"
    android:paddingTop="10dp"
    android:paddingBottom="10dp"
    android:background="?android:attr/selectableItemBackground">

    <!-- Avatar + status dot -->
    <FrameLayout
        android:layout_width="48dp"
        android:layout_height="48dp"
        android:layout_marginEnd="12dp">

        <androidx.cardview.widget.CardView
            android:layout_width="48dp"
            android:layout_height="48dp"
            app:cardCornerRadius="24dp"
            app:cardElevation="0dp">

            <ImageView
                android:id="@+id/ivAvatar"
                android:layout_width="48dp"
                android:layout_height="48dp"
                android:scaleType="centerCrop" />
        </androidx.cardview.widget.CardView>

        <TextView
            android:id="@+id/tvAvatarInitial"
            android:layout_width="48dp"
            android:layout_height="48dp"
            android:gravity="center"
            android:textColor="@color/white"
            android:textSize="18sp"
            android:textStyle="bold"
            android:background="@drawable/bg_avatar" />

        <View
            android:id="@+id/viewStatusDot"
            android:layout_width="12dp"
            android:layout_height="12dp"
            android:layout_gravity="bottom|end"
            android:background="@drawable/status_dot_offline" />
    </FrameLayout>

    <LinearLayout
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_weight="1"
        android:orientation="vertical">

        <TextView
            android:id="@+id/tvFriendName"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:textColor="@color/text_dark"
            android:textSize="14sp"
            android:textStyle="bold" />

        <TextView
            android:id="@+id/tvFriendStatus"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:textColor="@color/text_muted"
            android:textSize="12sp"
            android:layout_marginTop="2dp" />
    </LinearLayout>

    <LinearLayout
        android:id="@+id/layoutActions"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical">

        <ImageView
            android:id="@+id/btnChat"
            android:layout_width="36dp"
            android:layout_height="36dp"
            android:background="@drawable/bg_input"
            android:padding="8dp"
            android:src="@android:drawable/ic_dialog_email"
            android:clickable="true"
            android:focusable="true"
            android:layout_marginEnd="6dp" />

        <ImageView
            android:id="@+id/btnCall"
            android:layout_width="36dp"
            android:layout_height="36dp"
            android:background="@drawable/bg_btn_primary"
            android:padding="8dp"
            android:src="@android:drawable/ic_menu_call"
            android:clickable="true"
            android:focusable="true" />
    </LinearLayout>

    <LinearLayout
        android:id="@+id/layoutRequestActions"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:visibility="gone">

        <androidx.appcompat.widget.AppCompatButton
            android:id="@+id/btnAccept"
            android:layout_width="wrap_content"
            android:layout_height="32dp"
            android:background="@drawable/bg_btn_primary"
            android:text="@string/action_accept"
            android:textColor="@color/white"
            android:textSize="11sp"
            android:textStyle="bold"
            android:paddingStart="12dp"
            android:paddingEnd="12dp"
            android:layout_marginEnd="6dp"
            android:textAllCaps="false"
            android:minHeight="0dp"
            android:minWidth="0dp" />

        <androidx.appcompat.widget.AppCompatButton
            android:id="@+id/btnReject"
            android:layout_width="wrap_content"
            android:layout_height="32dp"
            android:background="@drawable/bg_btn_outline"
            android:text="@string/action_reject"
            android:textColor="@color/text_muted"
            android:textSize="11sp"
            android:paddingStart="12dp"
            android:paddingEnd="12dp"
            android:textAllCaps="false"
            android:minHeight="0dp"
            android:minWidth="0dp" />
    </LinearLayout>

</LinearLayout>
