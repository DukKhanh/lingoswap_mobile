<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:background="@color/white"
    android:orientation="horizontal"
    android:gravity="center_vertical"
    android:padding="12dp"
    android:layout_marginBottom="8dp">

    <!-- Avatar + online dot -->
    <FrameLayout
        android:layout_width="48dp"
        android:layout_height="48dp">

        <androidx.cardview.widget.CardView
            android:layout_width="48dp"
            android:layout_height="48dp"
            app:cardCornerRadius="24dp"
            app:cardElevation="0dp">

            <ImageView
                android:id="@+id/ivFriendAvatar"
                android:layout_width="48dp"
                android:layout_height="48dp"
                android:scaleType="centerCrop"
                android:src="@android:drawable/sym_def_app_icon" />
        </androidx.cardview.widget.CardView>

        <!-- Online indicator dot -->
        <View
            android:id="@+id/viewOnlineDot"
            android:layout_width="12dp"
            android:layout_height="12dp"
            android:layout_gravity="bottom|end"
            android:background="@drawable/bg_online_dot"
            android:visibility="gone" />
    </FrameLayout>

    <!-- Name + last message / language tags -->
    <LinearLayout
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_weight="1"
        android:orientation="vertical"
        android:paddingStart="12dp"
        android:paddingEnd="8dp">

        <TextView
            android:id="@+id/tvFriendName"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Nguyen Van A"
            android:textColor="@color/text_dark"
            android:textSize="15sp"
            android:textStyle="bold" />

        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:layout_marginTop="3dp">

            <!-- Language chip "VI → EN" -->
            <TextView
                android:id="@+id/tvFriendLangs"
                android:layout_width="wrap_content"
                android:layout_height="22dp"
                android:background="@drawable/bg_toggle_group"
                android:gravity="center"
                android:paddingStart="8dp"
                android:paddingEnd="8dp"
                android:text="VI → EN"
                android:textColor="@color/blue"
                android:textSize="11sp"
                android:textStyle="bold" />

            <TextView
                android:id="@+id/tvFriendStatus"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginStart="8dp"
                android:text="Online"
                android:textColor="@color/text_muted"
                android:textSize="12sp" />
        </LinearLayout>
    </LinearLayout>

    <!-- Action buttons -->
    <LinearLayout
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical">

        <!-- Chat button -->
        <ImageView
            android:id="@+id/btnFriendChat"
            android:layout_width="36dp"
            android:layout_height="36dp"
            android:background="@drawable/bg_input"
            android:padding="8dp"
            android:src="@android:drawable/ic_dialog_email"
            android:clickable="true"
            android:focusable="true"
            android:layout_marginEnd="6dp"
            app:tint="@color/blue" />

        <!-- Video call button -->
        <ImageView
            android:id="@+id/btnFriendCall"
            android:layout_width="36dp"
            android:layout_height="36dp"
            android:background="@drawable/bg_btn_primary"
            android:padding="8dp"
            android:src="@android:drawable/ic_menu_call"
            android:clickable="true"
            android:focusable="true"
            app:tint="@color/white" />
    </LinearLayout>
</LinearLayout>
