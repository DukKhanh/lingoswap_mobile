<?xml version="1.0" encoding="utf-8"?>
<!--
  item_friend.xml
  Handles two states:
    1. Regular friend  → shows chat/call/remove buttons
    2. Pending request → shows accept/reject buttons + sentAt time

  Required IDs referenced by FriendAdapter.VH:
    imgFriendAvatar, viewOnlineDot, tvFriendName, tvFriendStatus,
    tvSentAt, layoutFriendActions, btnFriendChat, btnFriendCall, btnFriendRemove,
    layoutRequestActions, btnAccept, btnReject
-->
<androidx.cardview.widget.CardView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginHorizontal="16dp"
    android:layout_marginVertical="6dp"
    app:cardCornerRadius="12dp"
    app:cardElevation="2dp"
    app:cardBackgroundColor="?attr/colorSurface">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:padding="12dp"
        android:gravity="center_vertical">

        <!-- Avatar + online dot -->
        <FrameLayout
            android:layout_width="48dp"
            android:layout_height="48dp">

            <ImageView
                android:id="@+id/imgFriendAvatar"
                android:layout_width="48dp"
                android:layout_height="48dp"
                android:scaleType="centerCrop"
                android:src="@drawable/ic_default_avatar" />

            <View
                android:id="@+id/viewOnlineDot"
                android:layout_width="12dp"
                android:layout_height="12dp"
                android:layout_gravity="bottom|end"
                android:background="@drawable/bg_online_dot"
                android:visibility="gone" />
        </FrameLayout>

        <!-- Name + status -->
        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:orientation="vertical"
            android:layout_marginStart="12dp">

            <TextView
                android:id="@+id/tvFriendName"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:textSize="15sp"
                android:textStyle="bold"
                android:textColor="?attr/colorOnSurface"
                android:maxLines="1"
                android:ellipsize="end" />

            <TextView
                android:id="@+id/tvFriendStatus"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:textSize="12sp"
                android:textColor="?attr/colorOnSurfaceVariant"
                android:layout_marginTop="2dp" />

            <TextView
                android:id="@+id/tvSentAt"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:textSize="11sp"
                android:textColor="?attr/colorOnSurfaceVariant"
                android:layout_marginTop="2dp"
                android:visibility="gone" />
        </LinearLayout>

        <!-- Friend actions (chat / call / remove) -->
        <LinearLayout
            android:id="@+id/layoutFriendActions"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:visibility="visible">

            <ImageView
                android:id="@+id/btnFriendChat"
                android:layout_width="36dp"
                android:layout_height="36dp"
                android:padding="6dp"
                android:src="@drawable/ic_chat"
                android:contentDescription="@string/action_chat"
                android:background="?attr/selectableItemBackgroundBorderless" />

            <ImageView
                android:id="@+id/btnFriendCall"
                android:layout_width="36dp"
                android:layout_height="36dp"
                android:padding="6dp"
                android:layout_marginStart="4dp"
                android:src="@drawable/ic_video_call"
                android:contentDescription="@string/action_call"
                android:background="?attr/selectableItemBackgroundBorderless" />

            <ImageView
                android:id="@+id/btnFriendRemove"
                android:layout_width="36dp"
                android:layout_height="36dp"
                android:padding="6dp"
                android:layout_marginStart="4dp"
                android:src="@drawable/ic_remove_friend"
                android:contentDescription="@string/action_remove_friend"
                android:background="?attr/selectableItemBackgroundBorderless"
                android:tint="@color/error_red" />
        </LinearLayout>

        <!-- Request actions (accept / reject) -->
        <LinearLayout
            android:id="@+id/layoutRequestActions"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:visibility="gone">

            <TextView
                android:id="@+id/btnAccept"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/action_accept"
                android:textColor="@color/white"
                android:background="@drawable/bg_btn_primary"
                android:paddingHorizontal="14dp"
                android:paddingVertical="7dp"
                android:textSize="13sp"
                android:textStyle="bold" />

            <TextView
                android:id="@+id/btnReject"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/action_reject"
                android:textColor="?attr/colorOnSurfaceVariant"
                android:background="@drawable/bg_btn_secondary"
                android:paddingHorizontal="14dp"
                android:paddingVertical="7dp"
                android:textSize="13sp"
                android:layout_marginStart="8dp" />
        </LinearLayout>

    </LinearLayout>
</androidx.cardview.widget.CardView>
