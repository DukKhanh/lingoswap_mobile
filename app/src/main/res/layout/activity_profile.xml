<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/bg"
    android:orientation="vertical">

<ScrollView
    android:layout_width="match_parent"
    android:layout_height="0dp"
    android:layout_weight="1"
    android:fillViewport="true">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="20dp">

        <TextView
            android:id="@+id/tvBackHome"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/profile_back"
            android:textColor="@color/blue"
            android:textSize="13sp"
            android:layout_marginBottom="12dp"
            android:visibility="gone"
            android:clickable="true"
            android:focusable="true"/>

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="@string/profile_title"
            android:textColor="@color/text_dark"
            android:textSize="24sp"
            android:textStyle="bold"
            android:layout_marginBottom="16dp"/>

        <androidx.cardview.widget.CardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            app:cardCornerRadius="16dp"
            app:cardElevation="4dp"
            app:cardBackgroundColor="@color/white"
            android:layout_marginBottom="16dp">
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:gravity="center"
                android:padding="24dp">

                <FrameLayout
                    android:id="@+id/flAvatar"
                    android:layout_width="80dp"
                    android:layout_height="80dp"
                    android:background="@drawable/bg_avatar"
                    android:layout_marginBottom="12dp"
                    android:clickable="true"
                    android:focusable="true">
                    <TextView
                        android:id="@+id/tvHeroInitial"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_gravity="center"
                        android:text="T"
                        android:textColor="@color/white"
                        android:textSize="32sp"
                        android:textStyle="bold"/>
                    <ImageView
                        android:id="@+id/ivAvatar"
                        android:layout_width="match_parent"
                        android:layout_height="match_parent"
                        android:scaleType="centerCrop"
                        android:visibility="gone"
                        android:contentDescription="@string/profile_photo_hint"/>
                </FrameLayout>

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="@string/profile_photo_hint"
                    android:textColor="@color/text_light"
                    android:textSize="11sp"
                    android:gravity="center"
                    android:layout_marginBottom="10dp"/>

                <TextView
                    android:id="@+id/tvHeroName"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="TruongKAr"
                    android:textColor="@color/text_dark"
                    android:textSize="18sp"
                    android:textStyle="bold"
                    android:layout_marginBottom="2dp"/>

                <TextView
                    android:id="@+id/tvHeroEmail"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="user@gmail.com"
                    android:textColor="@color/text_muted"
                    android:textSize="13sp"
                    android:layout_marginBottom="16dp"/>

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal">
                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:orientation="vertical"
                        android:gravity="center">
                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="@string/profile_stat_streak"
                            android:textColor="@color/text_light"
                            android:textSize="10sp"
                            android:textStyle="bold"
                            android:letterSpacing="0.06"
                            android:layout_marginBottom="3dp"/>
                        <TextView
                            android:id="@+id/tvHeroStreak"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="0"
                            android:drawablePadding="4dp"
                            app:drawableStartCompat="@drawable/ic_fire"
                            android:gravity="center_vertical"
                            android:textColor="@color/orange"
                            android:textSize="15sp"
                            android:textStyle="bold"/>
                    </LinearLayout>
                    <View
                        android:layout_width="1dp"
                        android:layout_height="match_parent"
                        android:background="@color/border"
                        android:layout_marginTop="4dp"
                        android:layout_marginBottom="4dp"/>
                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:orientation="vertical"
                        android:gravity="center">
                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="@string/profile_stat_sessions"
                            android:textColor="@color/text_light"
                            android:textSize="10sp"
                            android:textStyle="bold"
                            android:letterSpacing="0.06"
                            android:layout_marginBottom="3dp"/>
                        <TextView
                            android:id="@+id/tvHeroSessions"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="0"
                            android:textColor="@color/blue"
                            android:textSize="15sp"
                            android:textStyle="bold"/>
                    </LinearLayout>
                </LinearLayout>
            </LinearLayout>
        </androidx.cardview.widget.CardView>

        <androidx.cardview.widget.CardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            app:cardCornerRadius="16dp"
            app:cardElevation="4dp"
            app:cardBackgroundColor="@color/white"
            android:layout_marginBottom="16dp">
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="20dp">

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="@string/profile_edit_title"
                    android:textColor="@color/text_dark"
                    android:textSize="15sp"
                    android:textStyle="bold"
                    android:layout_marginBottom="16dp"/>

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="@string/profile_label_name"
                    android:textColor="@color/text_muted"
                    android:textSize="11sp"
                    android:textStyle="bold"
                    android:letterSpacing="0.08"
                    android:layout_marginBottom="6dp"/>
                <EditText
                    android:id="@+id/etFullName"
                    android:layout_width="match_parent"
                    android:layout_height="48dp"
                    android:background="@drawable/bg_input"
                    android:paddingStart="14dp"
                    android:paddingEnd="14dp"
                    android:textSize="14sp"
                    android:textColor="@color/text_dark"
                    android:layout_marginBottom="14dp"/>

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="@string/profile_label_bio"
                    android:textColor="@color/text_muted"
                    android:textSize="11sp"
                    android:textStyle="bold"
                    android:letterSpacing="0.08"
                    android:layout_marginBottom="6dp"/>
                <EditText
                    android:id="@+id/etBio"
                    android:layout_width="match_parent"
                    android:layout_height="80dp"
                    android:background="@drawable/bg_input"
                    android:padding="14dp"
                    android:textSize="14sp"
                    android:textColor="@color/text_dark"
                    android:inputType="textMultiLine"
                    android:gravity="top"
                    android:layout_marginBottom="14dp"/>

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="@string/profile_label_country"
                    android:textColor="@color/text_muted"
                    android:textSize="11sp"
                    android:textStyle="bold"
                    android:letterSpacing="0.08"
                    android:layout_marginBottom="6dp"/>
                <FrameLayout
                    android:layout_width="match_parent"
                    android:layout_height="48dp"
                    android:layout_marginBottom="14dp">
                    <Spinner
                        android:id="@+id/spinnerCountry"
                        android:layout_width="match_parent"
                        android:layout_height="match_parent"
                        android:background="@drawable/bg_input"
                        android:paddingStart="14dp"
                        android:paddingEnd="14dp"/>
                </FrameLayout>

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="@string/profile_label_email"
                    android:textColor="@color/text_muted"
                    android:textSize="11sp"
                    android:textStyle="bold"
                    android:letterSpacing="0.08"
                    android:layout_marginBottom="6dp"/>
                <EditText
                    android:id="@+id/etEmail"
                    android:layout_width="match_parent"
                    android:layout_height="48dp"
                    android:background="@drawable/bg_input"
                    android:paddingStart="14dp"
                    android:paddingEnd="14dp"
                    android:textSize="14sp"
                    android:textColor="@color/text_dark"
                    android:layout_marginBottom="16dp"/>

                <Button
                    android:id="@+id/btnSaveProfile"
                    android:layout_width="wrap_content"
                    android:layout_height="44dp"
                    android:background="@drawable/bg_btn_primary"
                    android:text="@string/profile_btn_save"
                    android:textColor="@color/white"
                    android:textSize="14sp"
                    android:textStyle="bold"
                    android:paddingStart="20dp"
                    android:paddingEnd="20dp"
                    style="?android:attr/borderlessButtonStyle"/>
            </LinearLayout>
        </androidx.cardview.widget.CardView>

        <androidx.cardview.widget.CardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            app:cardCornerRadius="16dp"
            app:cardElevation="4dp"
            app:cardBackgroundColor="@color/white"
            android:layout_marginBottom="16dp">
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="20dp">

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="@string/profile_settings_title"
                    android:textColor="@color/text_dark"
                    android:textSize="15sp"
                    android:textStyle="bold"
                    android:layout_marginBottom="16dp"/>

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="@string/profile_appearance"
                    android:textColor="@color/text_muted"
                    android:textSize="11sp"
                    android:textStyle="bold"
                    android:letterSpacing="0.08"
                    android:layout_marginBottom="8dp"/>

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:layout_marginBottom="16dp"
                    android:baselineAligned="false">

                    <LinearLayout
                        android:id="@+id/appearLight"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:orientation="vertical"
                        android:background="@drawable/bg_lang_option_selected"
                        android:layout_marginEnd="5dp"
                        android:clickable="true"
                        android:focusable="true">
                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="48dp"
                            android:background="#F8FAFC"
                            android:orientation="vertical"
                            android:padding="10dp"
                            android:gravity="center_vertical">
                            <View
                                android:layout_width="80dp"
                                android:layout_height="5dp"
                                android:background="@color/blue"/>
                            <View
                                android:layout_width="60dp"
                                android:layout_height="5dp"
                                android:background="#CBD5E1"
                                android:layout_marginTop="4dp"/>
                        </LinearLayout>
                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:orientation="horizontal"
                            android:gravity="center_vertical"
                            android:padding="8dp"
                            android:background="@color/white">
                            <TextView
                                android:layout_width="0dp"
                                android:layout_height="wrap_content"
                                android:layout_weight="1"
                                android:text="@string/profile_light"
                                android:drawablePadding="8dp"
                                app:drawableStartCompat="@drawable/ic_sun"
                                app:drawableTint="@color/blue"
                                android:gravity="center_vertical"
                                android:textColor="@color/blue"
                                android:textSize="12sp"/>
                            <FrameLayout
                                android:id="@+id/frameLightCheck"
                                android:layout_width="14dp"
                                android:layout_height="14dp"
                                android:background="@drawable/bg_ctrl_btn">
                                <ImageView
                                    android:layout_width="10dp"
                                    android:layout_height="10dp"
                                    android:layout_gravity="center"
                                    android:src="@drawable/ic_check"
                                    app:tint="@color/white"/>
                            </FrameLayout>
                        </LinearLayout>
                    </LinearLayout>

                    <LinearLayout
                        android:id="@+id/appearDark"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:orientation="vertical"
                        android:background="@drawable/bg_lang_option"
                        android:layout_marginStart="5dp"
                        android:clickable="true"
                        android:focusable="true">
                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="48dp"
                            android:background="@color/dark_surface"
                            android:orientation="vertical"
                            android:padding="10dp"
                            android:gravity="center_vertical">
                            <View
                                android:layout_width="80dp"
                                android:layout_height="5dp"
                                android:background="@color/blue"/>
                            <View
                                android:layout_width="60dp"
                                android:layout_height="5dp"
                                android:background="#475569"
                                android:layout_marginTop="4dp"/>
                        </LinearLayout>
                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:orientation="horizontal"
                            android:gravity="center_vertical"
                            android:padding="8dp"
                            android:background="@color/white">
                            <TextView
                                android:layout_width="0dp"
                                android:layout_height="wrap_content"
                                android:layout_weight="1"
                                android:text="@string/profile_dark"
                                android:drawablePadding="8dp"
                                app:drawableStartCompat="@drawable/ic_moon"
                                app:drawableTint="@color/text_muted"
                                android:gravity="center_vertical"
                                android:textColor="@color/text_muted"
                                android:textSize="12sp"/>
                            <FrameLayout
                                android:id="@+id/frameDarkCheck"
                                android:layout_width="14dp"
                                android:layout_height="14dp">
                                <ImageView
                                    android:layout_width="10dp"
                                    android:layout_height="10dp"
                                    android:layout_gravity="center"
                                    android:src="@drawable/ic_check"
                                    app:tint="@color/white"
                                    android:visibility="gone"/>
                            </FrameLayout>
                        </LinearLayout>
                    </LinearLayout>
                </LinearLayout>

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="@string/profile_default_lang"
                    android:textColor="@color/text_muted"
                    android:textSize="11sp"
                    android:textStyle="bold"
                    android:letterSpacing="0.08"
                    android:layout_marginBottom="8dp"/>

                <Button
                    android:id="@+id/btnChangeLanguage"
                    android:layout_width="match_parent"
                    android:layout_height="48dp"
                    android:background="@drawable/bg_btn_primary"
                    android:text="English"
                    android:textColor="@color/white"
                    android:textSize="14sp"
                    android:drawablePadding="8dp"
                    app:drawableStartCompat="@drawable/ic_globe"
                    app:drawableTint="@color/white"
                    android:gravity="center_vertical|start"
                    android:paddingStart="14dp"
                    android:paddingEnd="14dp"
                    android:textAllCaps="false"
                    android:layout_marginBottom="16dp"
                    style="?android:attr/borderlessButtonStyle"/>

                <Button
                    android:id="@+id/btnSaveSettings"
                    android:layout_width="wrap_content"
                    android:layout_height="44dp"
                    android:background="@drawable/bg_btn_primary"
                    android:text="@string/profile_btn_save_settings"
                    android:textColor="@color/white"
                    android:textSize="14sp"
                    android:textStyle="bold"
                    android:paddingStart="20dp"
                    android:paddingEnd="20dp"
                    style="?android:attr/borderlessButtonStyle"/>
            </LinearLayout>
        </androidx.cardview.widget.CardView>

        <androidx.cardview.widget.CardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            app:cardCornerRadius="16dp"
            app:cardElevation="4dp"
            app:cardBackgroundColor="@color/white"
            android:layout_marginBottom="20dp">
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="20dp">

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="@string/profile_change_pw_title"
                    android:textColor="@color/text_dark"
                    android:textSize="15sp"
                    android:textStyle="bold"
                    android:layout_marginBottom="16dp"/>

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="@string/profile_label_current_pw"
                    android:textColor="@color/text_muted"
                    android:textSize="11sp"
                    android:textStyle="bold"
                    android:letterSpacing="0.08"
                    android:layout_marginBottom="6dp"/>
                <FrameLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginBottom="14dp">
                    <EditText
                        android:id="@+id/etCurrentPw"
                        android:layout_width="match_parent"
                        android:layout_height="50dp"
                        android:background="@drawable/bg_input"
                        android:paddingStart="44dp"
                        android:paddingEnd="44dp"
                        android:inputType="textPassword"
                        android:textSize="15sp"
                        android:textColor="@color/text_dark"/>
                    <ImageView
                        android:layout_width="20dp"
                        android:layout_height="20dp"
                        android:layout_gravity="center_vertical"
                        android:layout_marginStart="13dp"
                        android:src="@android:drawable/ic_lock_lock"
                        android:tint="@color/text_light"/>
                </FrameLayout>

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="@string/profile_label_new_pw"
                    android:textColor="@color/text_muted"
                    android:textSize="11sp"
                    android:textStyle="bold"
                    android:letterSpacing="0.08"
                    android:layout_marginBottom="6dp"/>
                <FrameLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginBottom="14dp">
                    <EditText
                        android:id="@+id/etNewPw"
                        android:layout_width="match_parent"
                        android:layout_height="50dp"
                        android:background="@drawable/bg_input"
                        android:paddingStart="44dp"
                        android:paddingEnd="44dp"
                        android:inputType="textPassword"
                        android:textSize="15sp"
                        android:textColor="@color/text_dark"/>
                    <ImageView
                        android:layout_width="20dp"
                        android:layout_height="20dp"
                        android:layout_gravity="center_vertical"
                        android:layout_marginStart="13dp"
                        android:src="@android:drawable/ic_lock_lock"
                        android:tint="@color/text_light"/>
                </FrameLayout>

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="@string/profile_label_confirm_pw"
                    android:textColor="@color/text_muted"
                    android:textSize="11sp"
                    android:textStyle="bold"
                    android:letterSpacing="0.08"
                    android:layout_marginBottom="6dp"/>
                <FrameLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginBottom="16dp">
                    <EditText
                        android:id="@+id/etConfirmNewPw"
                        android:layout_width="match_parent"
                        android:layout_height="50dp"
                        android:background="@drawable/bg_input"
                        android:paddingStart="44dp"
                        android:paddingEnd="44dp"
                        android:inputType="textPassword"
                        android:textSize="15sp"
                        android:textColor="@color/text_dark"/>
                    <ImageView
                        android:layout_width="20dp"
                        android:layout_height="20dp"
                        android:layout_gravity="center_vertical"
                        android:layout_marginStart="13dp"
                        android:src="@android:drawable/ic_lock_lock"
                        android:tint="@color/text_light"/>
                </FrameLayout>

                <Button
                    android:id="@+id/btnUpdatePassword"
                    android:layout_width="wrap_content"
                    android:layout_height="44dp"
                    android:background="@drawable/bg_btn_primary"
                    android:text="@string/profile_btn_update_pw"
                    android:textColor="@color/white"
                    android:textSize="14sp"
                    android:textStyle="bold"
                    android:paddingStart="20dp"
                    android:paddingEnd="20dp"
                    style="?android:attr/borderlessButtonStyle"/>
            </LinearLayout>
        </androidx.cardview.widget.CardView>

        <Button
            android:id="@+id/btnLogout"
            android:layout_width="match_parent"
            android:layout_height="50dp"
            android:background="@drawable/bg_btn_logout"
            android:backgroundTint="@null"
            android:text="@string/profile_btn_logout"
            android:textColor="@color/red"
            android:textSize="14sp"
            android:textStyle="bold"
            android:textAllCaps="false"
            android:drawablePadding="8dp"
            app:drawableStartCompat="@drawable/ic_logout"
            app:drawableTint="@color/red"
            android:layout_marginBottom="24dp"/>

    </LinearLayout>
</ScrollView>

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="56dp"
        android:background="@drawable/bg_bottom_nav"
        android:elevation="8dp"
        android:gravity="center"
        android:orientation="horizontal">

        <LinearLayout android:id="@+id/navHome"
            android:layout_width="0dp" android:layout_height="match_parent"
            android:layout_weight="1" android:gravity="center" android:orientation="vertical"
            android:clickable="true" android:focusable="true">
            <ImageView android:layout_width="22dp" android:layout_height="22dp"
                android:src="@drawable/ic_home" app:tint="@color/text_muted" />
            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                android:text="@string/nav_home" android:textSize="9sp" android:textColor="@color/text_muted" />
        </LinearLayout>

        <LinearLayout android:id="@+id/navFriends"
            android:layout_width="0dp" android:layout_height="match_parent"
            android:layout_weight="1" android:gravity="center" android:orientation="vertical"
            android:clickable="true" android:focusable="true">
            <ImageView android:layout_width="22dp" android:layout_height="22dp"
                android:src="@drawable/ic_friends" app:tint="@color/text_muted" />
            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                android:text="@string/nav_friends" android:textSize="9sp" android:textColor="@color/text_muted" />
        </LinearLayout>

        <LinearLayout android:id="@+id/navMatch"
            android:layout_width="0dp" android:layout_height="match_parent"
            android:layout_weight="1" android:gravity="center" android:orientation="vertical"
            android:clickable="true" android:focusable="true">
            <ImageView android:layout_width="22dp" android:layout_height="22dp"
                android:src="@drawable/ic_search" app:tint="@color/text_muted" />
            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                android:text="@string/nav_match" android:textSize="9sp" android:textColor="@color/text_muted" />
        </LinearLayout>

        <LinearLayout android:id="@+id/navChat"
            android:layout_width="0dp" android:layout_height="match_parent"
            android:layout_weight="1" android:gravity="center" android:orientation="vertical"
            android:clickable="true" android:focusable="true">
            <FrameLayout android:layout_width="wrap_content" android:layout_height="wrap_content">
                <ImageView android:layout_width="22dp" android:layout_height="22dp"
                    android:src="@drawable/ic_chat" app:tint="@color/text_muted" />
                <View android:id="@+id/chatUnreadDot"
                    android:layout_width="9dp" android:layout_height="9dp"
                    android:layout_gravity="top|end"
                    android:background="@drawable/bg_badge_red"
                    android:visibility="gone" />
            </FrameLayout>
            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                android:text="@string/nav_chat" android:textSize="9sp" android:textColor="@color/text_muted" />
        </LinearLayout>

        <LinearLayout android:id="@+id/navProfile"
            android:layout_width="0dp" android:layout_height="match_parent"
            android:layout_weight="1" android:gravity="center" android:orientation="vertical"
            android:clickable="true" android:focusable="true">
            <ImageView android:layout_width="22dp" android:layout_height="22dp"
                android:src="@drawable/ic_profile" app:tint="@color/blue" />
            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                android:text="@string/nav_profile" android:textSize="9sp" android:textColor="@color/blue" />
        </LinearLayout>
    </LinearLayout>

</LinearLayout>
