<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/bg"
    android:orientation="vertical">

    <!-- Lang Toggle Row -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:gravity="end|center_vertical"
        android:orientation="horizontal"
        android:paddingStart="20dp"
        android:paddingEnd="20dp"
        android:paddingTop="12dp"
        android:paddingBottom="4dp">

        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="42dp"
            android:background="@drawable/bg_toggle_group"
            android:gravity="center_vertical"
            android:orientation="horizontal"
            android:paddingStart="4dp"
            android:paddingEnd="4dp">

            <TextView
                android:id="@+id/btnLangVI"
                android:layout_width="wrap_content"
                android:layout_height="34dp"
                android:gravity="center"
                android:text="@string/lang_toggle_vi"
                android:textColor="@color/text_muted"
                android:textSize="13sp"
                android:paddingStart="16dp"
                android:paddingEnd="16dp"
                android:clickable="true"
                android:focusable="true"/>

            <TextView
                android:id="@+id/btnLangEN"
                android:layout_width="wrap_content"
                android:layout_height="34dp"
                android:background="@drawable/bg_tab_active"
                android:gravity="center"
                android:text="@string/lang_toggle_en"
                android:textColor="@color/white"
                android:textSize="13sp"
                android:textStyle="bold"
                android:paddingStart="16dp"
                android:paddingEnd="16dp"
                android:clickable="true"
                android:focusable="true"/>
        </LinearLayout>

        <TextView
            android:id="@+id/tvDarkToggle"
            android:layout_width="38dp"
            android:layout_height="38dp"
            android:background="@drawable/bg_toggle_group"
            android:gravity="center"
            android:layout_marginStart="8dp"
            android:text="🌙"
            android:textSize="18sp"
            android:clickable="true"
            android:focusable="true"/>
    </LinearLayout>

    <!-- Center content -->
    <FrameLayout android:layout_width="match_parent" android:layout_height="0dp" android:layout_weight="1">
        <androidx.cardview.widget.CardView
            android:layout_width="match_parent" android:layout_height="wrap_content"
            android:layout_gravity="center"
            android:layout_marginStart="20dp" android:layout_marginEnd="20dp"
            style="@style/Widget.LingoSwap.Card">

            <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
                android:orientation="vertical" android:padding="44dp" android:gravity="center">

                <!-- Success Icon -->
                <FrameLayout android:layout_width="64dp" android:layout_height="64dp"
                    android:background="@drawable/bg_success_icon" android:layout_marginBottom="20dp">
                    <ImageView android:layout_width="28dp" android:layout_height="28dp"
                        android:layout_gravity="center"
                        android:src="@android:drawable/ic_menu_send"
                        app:tint="@color/success_text"/>
                </FrameLayout>

                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                    android:text="@string/reset_success_title"
                    android:textColor="@color/text_dark" android:textSize="20sp" android:textStyle="bold"
                    android:gravity="center" android:layout_marginBottom="8dp"/>

                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                    android:text="@string/reset_success_sub"
                    android:textColor="@color/text_muted" android:textSize="14sp"
                    android:gravity="center" android:layout_marginBottom="24dp"/>

                <TextView android:id="@+id/tvBackToSignIn"
                    android:layout_width="wrap_content" android:layout_height="wrap_content"
                    android:text="@string/reset_success_back"
                    android:textColor="@color/blue" android:textSize="14sp"
                    android:clickable="true" android:focusable="true"/>
            </LinearLayout>
        </androidx.cardview.widget.CardView>
    </FrameLayout>
</LinearLayout>
