<?xml version="1.0" encoding="utf-8"?>
<manifest xmlns:android="http://schemas.android.com/apk/res/android"
    package="com.lingoswap">

    <uses-permission android:name="android.permission.INTERNET"/>
    <uses-permission android:name="android.permission.CAMERA"/>
    <uses-permission android:name="android.permission.RECORD_AUDIO"/>
    <uses-permission android:name="android.permission.MODIFY_AUDIO_SETTINGS"/>
    <uses-permission android:name="android.permission.ACCESS_NETWORK_STATE"/>

    <application
        android:name=".LingoSwapApp"
        android:allowBackup="true"
        android:icon="@drawable/bg_logo"
        android:label="@string/app_name"
        android:roundIcon="@drawable/bg_logo"
        android:supportsRtl="true"
        android:theme="@style/Theme.LingoSwap">

        <!-- Entry point -->
        <activity
            android:name=".activities.SignInActivity"
            android:exported="true"
            android:windowSoftInputMode="adjustResize">
            <intent-filter>
                <action android:name="android.intent.action.MAIN"/>
                <category android:name="android.intent.category.LAUNCHER"/>
            </intent-filter>
        </activity>

        <activity
            android:name=".activities.SignUpActivity"
            android:windowSoftInputMode="adjustResize"/>

        <activity
            android:name=".presentation.auth.forgotpassword.ForgotPasswordActivity"
            android:windowSoftInputMode="adjustResize"/>

        <activity
            android:name=".activities.ResetPasswordActivity"
            android:windowSoftInputMode="adjustResize"/>

        <activity android:name=".activities.ResetSuccessActivity"/>

        <activity android:name=".activities.HomeActivity"/>

        <activity
            android:name=".activities.MatchingActivity"
            android:screenOrientation="portrait"/>

        <activity
            android:name=".activities.VideoCallActivity"
            android:screenOrientation="portrait"
            android:theme="@style/Theme.LingoSwap.VideoCall"
            android:windowSoftInputMode="adjustResize"/>

        <activity
            android:name=".activities.RatingActivity"
            android:windowSoftInputMode="adjustResize"/>

        <activity
            android:name=".activities.ProfileActivity"
            android:windowSoftInputMode="adjustResize"/>

        <activity
            android:name=".presentation.friends.FriendsActivity"
            android:windowSoftInputMode="adjustResize"/>

        <activity
            android:name=".presentation.chat.ChatActivity"
            android:windowSoftInputMode="adjustResize"/>

    </application>
</manifest>
