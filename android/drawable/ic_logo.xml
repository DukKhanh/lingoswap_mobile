<?xml version="1.0" encoding="utf-8"?>
<!--
    LingoSwap Logo — ic_logo.xml
    Dùng: android:src="@drawable/ic_logo" trong ImageView
    Kích thước khuyến nghị: 32dp x 32dp trở lên

    Concept: Bong bóng chat (💬) + sóng âm (🔊) hòa thành logo
    nền gradient xanh-tím, chữ "LS" cách điệu bên trong.
-->
<vector xmlns:android="http://schemas.android.com/apk/res/android"
    android:width="48dp"
    android:height="48dp"
    android:viewportWidth="48"
    android:viewportHeight="48">

    <!-- Nền tròn gradient xanh → tím -->
    <path
        android:pathData="M24,2 C12,2 2,12 2,24 C2,36 12,46 24,46 C36,46 46,36 46,24 C46,12 36,2 24,2 Z"
        android:fillColor="#4F6EF7" />

    <!-- Sóng trái (âm thanh) -->
    <path
        android:pathData="M13,18 Q10,24 13,30"
        android:strokeColor="#FFFFFF"
        android:strokeWidth="2.5"
        android:strokeLineCap="round"
        android:fillColor="#00000000" />

    <!-- Sóng phải (âm thanh) -->
    <path
        android:pathData="M35,18 Q38,24 35,30"
        android:strokeColor="#FFFFFF"
        android:strokeWidth="2.5"
        android:strokeLineCap="round"
        android:fillColor="#00000000" />

    <!-- Chữ L -->
    <path
        android:pathData="M18,16 L18,28 L23,28"
        android:strokeColor="#FFFFFF"
        android:strokeWidth="3"
        android:strokeLineCap="round"
        android:strokeLineJoin="round"
        android:fillColor="#00000000" />

    <!-- Chữ S -->
    <path
        android:pathData="M26,16 Q31,16 31,20 Q31,24 26,24 Q30,24 30,28 Q30,32 26,32"
        android:strokeColor="#FFFFFF"
        android:strokeWidth="2.8"
        android:strokeLineCap="round"
        android:strokeLineJoin="round"
        android:fillColor="#00000000" />

</vector>
