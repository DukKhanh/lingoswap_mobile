<?xml version="1.0" encoding="utf-8"?>
<!-- item_message.xml – bubble cho mỗi tin nhắn trong ChatActivity -->
<!--
    Sử dụng: viewType = 0 (tin nhắn của mình, căn phải)
             viewType = 1 (tin nhắn đối phương, căn trái)
    ChatAdapter sẽ inflate layout này rồi dùng setGravity() để đổi chiều.
-->
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:id="@+id/layoutMessageRoot"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="horizontal"
    android:gravity="end"
    android:layout_marginBottom="6dp"
    android:paddingStart="4dp"
    android:paddingEnd="4dp">

    <!-- Avatar đối phương (chỉ hiện khi viewType = 1) -->
    <androidx.cardview.widget.CardView
        android:id="@+id/cvPartnerAvatar"
        android:layout_width="32dp"
        android:layout_height="32dp"
        android:layout_marginEnd="6dp"
        android:layout_gravity="bottom"
        android:visibility="gone"
        xmlns:app="http://schemas.android.com/apk/res-auto"
        app:cardCornerRadius="16dp"
        app:cardElevation="0dp">

        <ImageView
            android:id="@+id/ivMsgAvatar"
            android:layout_width="32dp"
            android:layout_height="32dp"
            android:scaleType="centerCrop"
            android:src="@android:drawable/sym_def_app_icon" />
    </androidx.cardview.widget.CardView>

    <!-- Bubble wrapper -->
    <LinearLayout
        android:id="@+id/layoutBubble"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:maxWidth="260dp"
        android:orientation="vertical"
        android:background="@drawable/bg_bubble_me"
        android:paddingStart="12dp"
        android:paddingEnd="12dp"
        android:paddingTop="8dp"
        android:paddingBottom="8dp">

        <!-- Message text -->
        <TextView
            android:id="@+id/tvMessageText"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Xin chào!"
            android:textColor="@color/white"
            android:textSize="14sp"
            android:lineSpacingExtra="2dp" />

        <!-- Translation (hiện khi user nhấn dịch) -->
        <TextView
            android:id="@+id/tvMessageTranslation"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Hello!"
            android:textColor="#CCFFFFFF"
            android:textSize="12sp"
            android:layout_marginTop="4dp"
            android:visibility="gone" />

        <!-- Timestamp -->
        <TextView
            android:id="@+id/tvMessageTime"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="10:30"
            android:textColor="#99FFFFFF"
            android:textSize="10sp"
            android:layout_gravity="end"
            android:layout_marginTop="4dp" />
    </LinearLayout>

</LinearLayout>
