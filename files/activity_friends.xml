<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/bg"
    android:orientation="vertical">

    <!-- ── Top Bar ─────────────────────────────────────────────── -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="56dp"
        android:background="@color/white"
        android:gravity="center_vertical"
        android:orientation="horizontal"
        android:paddingStart="16dp"
        android:paddingEnd="16dp"
        android:elevation="2dp">

        <TextView
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="Bạn bè"
            android:textColor="@color/text_dark"
            android:textSize="18sp"
            android:textStyle="bold" />

        <!-- Add friend icon -->
        <ImageView
            android:id="@+id/btnAddFriend"
            android:layout_width="36dp"
            android:layout_height="36dp"
            android:background="@drawable/bg_input"
            android:padding="8dp"
            android:src="@android:drawable/ic_input_add"
            android:clickable="true"
            android:focusable="true"
            app:tint="@color/blue" />
    </LinearLayout>

    <!-- ── Search Bar ───────────────────────────────────────────── -->
    <FrameLayout
        android:layout_width="match_parent"
        android:layout_height="44dp"
        android:layout_marginStart="16dp"
        android:layout_marginEnd="16dp"
        android:layout_marginTop="12dp"
        android:layout_marginBottom="4dp">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:background="@drawable/bg_input"
            android:gravity="center_vertical"
            android:orientation="horizontal"
            android:paddingStart="12dp">

            <ImageView
                android:layout_width="16dp"
                android:layout_height="16dp"
                android:src="@android:drawable/ic_menu_search"
                app:tint="@color/text_muted" />

            <EditText
                android:id="@+id/etSearchFriend"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:background="@android:color/transparent"
                android:hint="Tìm bạn bè..."
                android:textColor="@color/text_dark"
                android:textColorHint="@color/text_muted"
                android:textSize="14sp"
                android:paddingStart="8dp"
                android:inputType="text"
                android:imeOptions="actionSearch" />
        </LinearLayout>
    </FrameLayout>

    <!-- ── Tabs: Tất cả / Online / Lời mời ─────────────────────── -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="40dp"
        android:orientation="horizontal"
        android:paddingStart="16dp"
        android:paddingEnd="16dp"
        android:layout_marginTop="8dp"
        android:layout_marginBottom="4dp"
        android:background="@drawable/bg_toggle_group">

        <TextView
            android:id="@+id/tabFriendAll"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:background="@drawable/bg_tab_active"
            android:gravity="center"
            android:text="Tất cả"
            android:textColor="@color/white"
            android:textSize="13sp"
            android:textStyle="bold"
            android:clickable="true"
            android:focusable="true" />

        <TextView
            android:id="@+id/tabFriendOnline"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:background="@android:color/transparent"
            android:gravity="center"
            android:text="Online"
            android:textColor="@color/text_muted"
            android:textSize="13sp"
            android:clickable="true"
            android:focusable="true" />

        <TextView
            android:id="@+id/tabFriendRequests"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:background="@android:color/transparent"
            android:gravity="center"
            android:text="Lời mời"
            android:textColor="@color/text_muted"
            android:textSize="13sp"
            android:clickable="true"
            android:focusable="true" />
    </LinearLayout>

    <!-- ── Friends List (RecyclerView) ──────────────────────────── -->
    <androidx.recyclerview.widget.RecyclerView
        android:id="@+id/rvFriends"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:clipToPadding="false"
        android:paddingStart="16dp"
        android:paddingEnd="16dp"
        android:paddingTop="8dp"
        android:paddingBottom="8dp" />

    <!-- ── Empty State (hiển thị khi không có bạn bè) ───────────── -->
    <LinearLayout
        android:id="@+id/layoutEmptyFriends"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:gravity="center"
        android:orientation="vertical"
        android:visibility="gone">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="👥"
            android:textSize="48sp"
            android:layout_marginBottom="12dp" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Chưa có bạn bè nào"
            android:textColor="@color/text_dark"
            android:textSize="17sp"
            android:textStyle="bold"
            android:layout_marginBottom="6dp" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Tìm đối tác luyện tập và kết bạn ngay!"
            android:textColor="@color/text_muted"
            android:textSize="13sp"
            android:gravity="center"
            android:layout_marginBottom="20dp" />

        <Button
            android:id="@+id/btnFindNow"
            android:layout_width="wrap_content"
            android:layout_height="44dp"
            android:background="@drawable/bg_btn_primary"
            android:text="Tìm ngay"
            android:textColor="@color/white"
            android:textSize="14sp"
            android:textStyle="bold"
            android:paddingStart="32dp"
            android:paddingEnd="32dp" />
    </LinearLayout>

    <!-- ── Bottom Navigation ─────────────────────────────────────── -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="56dp"
        android:background="@drawable/bg_bottom_nav"
        android:elevation="8dp"
        android:gravity="center"
        android:orientation="horizontal">

        <LinearLayout android:id="@+id/navHome"
            android:layout_width="0dp" android:layout_height="match_parent"
            android:layout_weight="1" android:gravity="center" android:orientation="vertical"
            android:clickable="true" android:focusable="true">
            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                android:text="🏠" android:textSize="18sp"/>
            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                android:text="Home" android:textSize="9sp" android:textColor="@color/text_muted"/>
        </LinearLayout>

        <LinearLayout android:id="@+id/navFriends"
            android:layout_width="0dp" android:layout_height="match_parent"
            android:layout_weight="1" android:gravity="center" android:orientation="vertical"
            android:clickable="true" android:focusable="true">
            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                android:text="👥" android:textSize="18sp"/>
            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                android:text="Bạn bè" android:textSize="9sp" android:textColor="@color/blue"/>
        </LinearLayout>

        <LinearLayout android:id="@+id/navMatch"
            android:layout_width="0dp" android:layout_height="match_parent"
            android:layout_weight="1" android:gravity="center" android:orientation="vertical"
            android:clickable="true" android:focusable="true">
            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                android:text="🔍" android:textSize="18sp"/>
            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                android:text="Match" android:textSize="9sp" android:textColor="@color/text_muted"/>
        </LinearLayout>

        <LinearLayout android:id="@+id/navChat"
            android:layout_width="0dp" android:layout_height="match_parent"
            android:layout_weight="1" android:gravity="center" android:orientation="vertical"
            android:clickable="true" android:focusable="true">
            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                android:text="💬" android:textSize="18sp"/>
            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                android:text="Chat" android:textSize="9sp" android:textColor="@color/text_muted"/>
        </LinearLayout>

        <LinearLayout android:id="@+id/navProfile"
            android:layout_width="0dp" android:layout_height="match_parent"
            android:layout_weight="1" android:gravity="center" android:orientation="vertical"
            android:clickable="true" android:focusable="true">
            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                android:text="👤" android:textSize="18sp"/>
            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                android:text="Hồ sơ" android:textSize="9sp" android:textColor="@color/text_muted"/>
        </LinearLayout>
    </LinearLayout>

</LinearLayout>
